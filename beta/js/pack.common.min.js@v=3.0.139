pe)) {\r\n                            result.push(Object.assign({}, item));\r\n                        }\r\n                    });\r\n            });\r\n\r\n        return result;\r\n    }\r\n\r\n    static make(type, subtype) {\r\n        let weapons = ('Оружие' === type);\r\n        let items = ItemTooltip.fetch(this.sectionCode(type), subtype);\r\n\r\n        let html = '';\r\n        items.forEach(item => {\r\n            let parts = {\r\n                title: item.title,\r\n                kind: weapons ? item.kind : (item.kind + (item.strength ? ` (Сила: ${item.strength})` : '')),\r\n                stat: weapons ? item.damage : `КД: ${item.props}`,\r\n                props: weapons ? item.props : (item.stealth ? `Скрытность: ${item.stealth}` : ''),\r\n            };\r\n\r\n            html += `<div class=\"item-tooltip\">`;\r\n            html += `<div class=\"item-tooltip-column\"><span class=\"item_title\">${parts.title}</span><span class=\"item_stats_base\">${parts.stat}</span></div>`;\r\n            html += `<div class=\"item-tooltip-column\" style=\"width: 65%;\"><span class=\"item_type\">${parts.kind}</span><span class=\"item_stats_extra\">${parts.props}</span></div>`;\r\n            html += `</div>`;\r\n        });\r\n        return html;\r\n    }\r\n\r\n    static prepare(root) {\r\n        let ItemTooltipReplace = (match, type, subtype) => {\r\n            let links = {\r\n                \"https://dnd.su/articles/inventory/96-arms/\" : [\"любое\", \"любое рукопашное\", \"любое дальнобойное или метательное\"],\r\n                //\"https://dnd.su/articles/inventory/95-armor_and_shields/\" : [\"легкий, средний, тяжелый\"],\r\n            };\r\n            for (const [link, samples] of Object.entries(links)) {\r\n                if (samples.includes(subtype)) {\r\n                    return `${type} (<a href=\"${link}\">${subtype}</a>)`;\r\n                }\r\n            }\r\n\r\n            let substitute = {\r\n                \"средний или тяжелый, кроме шкурного\": \"любой металлик\",\r\n                \"средний, тяжелый\": \"любой средний, любой тяжелый\",\r\n                \"легкий, средний, тяжелый\": \"любой легкий, любой средний, любой тяжелый\",\r\n                \"любой меч, наносящий рубящий урон\": \"любой рубящий меч\",\r\n            };\r\n            let search = subtype;\r\n            for (const [key, replace] of Object.entries(substitute)) {\r\n                if (0 === ItemTooltip.keystring(subtype).localeCompare(key, undefined, { ignorePunctuation: true, sensitivity: 'base' })) {\r\n                    search = replace;\r\n                    break;\r\n                }\r\n            }\r\n\r\n            ItemTooltip.context.weapons = ('Оружие' === type);\r\n            ItemTooltip.context.content = ItemTooltip.make(type, search);\r\n            if (!ItemTooltip.context.content) {\r\n                return match;\r\n            }\r\n\r\n\r\n            let result = `${type} (<span class=\"item-tooltip\">${subtype}</span>)`;\r\n\r\n            return result;\r\n        };\r\n\r\n        let typeRE = /^(Оружие|Доспех)\\s+\\(([^)]+)\\)/ig;\r\n        root = $(root || document);\r\n        root.find('li.size-type-alignment').each((i, li) => {\r\n            HTML.fetchTextNodes(li, node => typeRE.test(node.data)).forEach(text =>\r\n                $(text).replaceWith(\r\n                    text.nodeValue.replace(typeRE, ItemTooltipReplace)\r\n                )\r\n            )\r\n\r\n            let tooltipWidth = ItemTooltip.context.weapons ? 310 : 290;// style=\"width:${tooltipWidth}px;\"\r\n            if ($(li).find('span.item-tooltip').length) {\r\n                $(li).find('span.item-tooltip').eq(0)\r\n                    .addClass('tooltip')\r\n                    .tooltipster({\r\n                        content: $(`<div>${ItemTooltip.context.content}</div>`),\r\n                        delay: 0,\r\n                        maxWidth: tooltipWidth,\r\n                        theme:
ase 'placeholder':\n                case 'id':\n                case 'index':\n                {\n                    // console.log(key, value);\n                    el.setAttribute(`data-${key}`, value);\n                } break;\n                default: {\n                    // console.log(key, el[key], el.hasAttribute(key));\n                    if ('undefined' === typeof(el[key])) {\n                        el.setAttribute(key, value);\n                    } else {\n                        el[key] = value;\n                    }\n                }\n            }\n        });\n\n        children.forEach((child) => {\n            // console.log(el, child);\n            el.appendChild(child);\n        });\n\n        return el;\n    }\n}\n\n//# sourceURL=webpack://DnD.su/./source/scripts/modules/Lib/HTML.js?");


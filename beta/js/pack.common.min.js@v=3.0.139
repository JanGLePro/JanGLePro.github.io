татус блока из хранилища\r\n     * @returns {DmsblockStatus}\r\n     */\r\n    getStatus() {\r\n        this.status = this.index in this.parent.status.blocks ? this.parent.status.blocks[this.index] : {}\r\n        return Object.assign(this.getDefaultStatus(), this.status)\r\n    }\r\n\r\n    /**\r\n     * получить статус блока от самого блока\r\n     */\r\n    setStatus() {\r\n        this.status.x = (parseFloat(this.block.getAttribute('data-x')) || 0)\r\n        this.status.y = (parseFloat(this.block.getAttribute('data-y')) || 0)\r\n        this.status.z = parseInt(this.block.style.zIndex) || 1\r\n        this.status.width = this.block.offsetWidth\r\n        this.status.height = this.block.offsetHeight\r\n        this.status.pin = this.block.classList.contains('pinned')\r\n\r\n        this.saveStatus()\r\n    }\r\n\r\n    /**\r\n     * Запись статуса блока в хранилище\r\n     */\r\n    saveStatus() {\r\n        this.parent.status.blocks[this.index] = this.status\r\n        this.parent.saveStatus()\r\n    }\r\n\r\n    /**\r\n     * Корректировка размера блока\r\n     */\r\n    snapSize() {\r\n        this.block.style.width = Math.ceil(this.block.offsetWidth / this.parent.grid) * this.parent.grid + 'px'\r\n        this.block.style.height = Math.ceil(this.block.offsetHeight / this.parent.grid) * this.parent.grid + 'px'\r\n\r\n        this.snapPosition()\r\n    }\r\n\r\n    /**\r\n     * корректировка позиции блока\r\n     */\r\n    snapPosition() {\r\n        let x = parseFloat(this.block.getAttribute('data-x')) || 0\r\n        let left = Math.ceil(x / this.parent.grid) * this.parent.grid\r\n        this.block.style.left = left + 'px'\r\n        this.block.setAttribute('data-x', left)\r\n\r\n        let y = parseFloat(this.block.getAttribute('data-y')) || 0\r\n        let top = Math.ceil(y / this.parent.grid) * this.parent.grid\r\n        this.block.style.top = top + 'px'\r\n        this.block.setAttribute('data-y', top)\r\n\r\n        this.setStatus()\r\n    }\r\n\r\n    /**\r\n     * Проверяет, можно ли перемещать/ресайзить блок, или курсор над элементом, который запрещает это\r\n     * @returns {boolean}\r\n     */\r\n    isInterractable() {\r\n        let can = true\r\n        this.block.querySelectorAll('.prevent-drag-focus').forEach((elem) => {\r\n            if (elem.matches(':focus')) {\r\n                can = false\r\n            }\r\n        })\r\n        this.block.querySelectorAll('.prevent-drag-hover').forEach((elem) => {\r\n            if (elem.matches(':hover')) {\r\n                can = false\r\n            }\r\n        })\r\n        return can\r\n    }\r\n\r\n    /**\r\n     * Перемещение блока\r\n     * @param event\r\n     */\r\n    dragMoveListener(event) {\r\n        if (this.isInterractable()) {\r\n            let x = (parseFloat(this.block.getAttribute('data-x')) || 0) + event.dx\r\n            let y = (parseFloat(this.block.getAttribute('data-y')) || 0) + event.dy\r\n\r\n            this.block.style.top = y + 'px'\r\n            this.block.style.left = x + 'px'\r\n\r\n            this.block.setAttribute('data-x', x)\r\n            this.block.setAttribute('data-y', y)\r\n\r\n            this.parent.added = 0\r\n        }\r\n    }\r\n\r\n    /**\r\n     * Изменение размера блока\r\n     * @param event\r\n     */\r\n    dragResizeListener(event) {\r\n        if (this.isInterractable()) {\r\n            let x = (parseFloat(this.block.getAttribute('data-x')) || 0)\r\n            let y = (parseFloat(this.block.getAttribute('data-y')) || 0)\r\n\r\n            this.block.style.width = event.rect.width + 'px'\r\n            this.block.style.height = event.rect.height + 'px'\r\n            x += event.deltaRect.left\r\n            y += event.deltaRect.top\r\n\r\n            this.block.style.top = y + 'px'\r\n            this.block.style.left = x + 'px'\r\n\r\n            this.block.setAttribute('data-x', x)\r\n            this.block.setAttribute('data-y', y)\r\n        }\r\n    }\r\n\r\n    /**\r\n     * перенос блока на верхний слой\r\n     */\r\n    setZ() {\r\n        this.parent.maxZ++\r\n        this.block.style.zIndex = this.parent.maxZ\r\n        this.setStatus()\r\n    }\r\n\r\n    async menuItemClick(item) {\r\n        let action = item.getAttribute('data-action')\r\n        let href = item.getAttribute('data-href') || null\r\n        let data = {}\r\n        data.result = false\r\n\r\n        if (href) {\r\n            const httpClient = new HttpClient();\r\n            let url = href.replace('{}', this.index)\r\n            data = await httpClient.get(url);\r\n        }\r\n\r\n        if ((href && data.result) || href === null) {\r\n            switch (action) {\r\n                case 'drop':\r\n                    this.parent.removeBlock(this)\r\n                    break\r\n\r\n                case 'pin':\r\n                    let pin = !this.status.pin\r\n                    this.status.pin = pin\r\n                    this.block.querySelector('[data-action=\"pin\"]').innerText = pin ? 'Открепить' : 'Закрепить';\r\n                    this.action.options.drag.enabled = !pin\r\n                    this.action.options.resize.enabled = !pin\r\n                    this.block.classList.toggle('pinned', pin)\r\n                    this.setStatus()\r\n                    break\r\n\r\n                default:\r\n                    console.log('unknown action')\r\n                    break\r\n            }\r\n        }\r\n    }\r\n\r\n    /**\r\n     * Инициализация меню блока\r\n     */\r\n    initMenuItems() {\r\n        this.block.querySelectorAll('.dms-card-link-need-init').forEach(item => {\r\n            item.onclick = async () => this.menuItemClick(item);\r\n            item.classList.remove('dms-card-link-need-init');\r\n        });\r\n    }\r\n\r\n    getTitle() {\r\n        return this.block.querySelector('.card__header .card-title').innerText;\r\n    }\r\n\r\n    handleEvent(ev, checkOnly = true) {\r\n        return false;\r\n    }\r\n}\r\n\r\nclass NotepadDmsblock extends  Dmsblock {\r\n    field = null;\r\n    value = '';\r\n\r\n    constructor(elem, parent) {\r\n        super(elem, parent);\r\n        this.initNotepad();\r\n    }\r\n\r\n    /**\r\n     * Дополнительные функции блокнота\r\n     */\r\n    initNotepad() {\r\n\r\n        this.field = this.block.querySelector('.dms-notepad__field')\r\n        this.value = this.field.innerHTML\r\n\r\n        if (this.parent.readOnly) {\r\n            return;\r\n        }\r\n\r\n        this.field.addEventListener('click', () => {\r\n            this.field.setAttribute('contenteditable', true)\r\n            this.field.focus()\r\n        })\r\n\r\n        this.field.addEventListener('paste', () => {\r\n            //this.field.innerHTML = this.field.innerText\r\n        })\r\n\r\n        this.field.addEventListener('focusout', async () => {\r\n            if (this.value !== this.field.innerHTML) {\r\n                const data = await ApiRequest.uploadString(`/api/dmscreen/page/${this.parent.index}/id/${this.index}/do/notepadupdate/`, this.field.innerHTML, 'value')\r\n                if (data.result) {\r\n                    this.field.removeAttribute('contenteditable')\r\n                    this.value = data.data.result.value\r\n                    this.field.innerHTML = this.value\r\n                }\r\n            }\r\n        })\r\n    }\r\n}\r\n\n\n//# sourceURL=webpack://DnD.su/./source/scripts/modules/Dmscreen/Dmsblock.js?");


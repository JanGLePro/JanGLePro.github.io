"use strict";
eval("__webpack_require__.r(__webpack_exports__);\n/* harmony export */ __webpack_require__.d(__webpack_exports__, {\n/* harmony export */   TooltipData_terms: () => (/* binding */ TooltipData_terms),\n/* harmony export */   items: () => (/* binding */ items)\n/* harmony export */ });\nconst TooltipData_terms = [\n    { key: \"weapon.ammo\",\n        desc: \"<b>Боеприпас.</b> Вы можете использовать оружие со свойством «боеприпас» для совершения дальнобойной атаки, только если у вас есть боеприпасы для стрельбы. Каждый раз, когда вы совершаете атаку с помощью этого оружия, вы тратите один боеприпас. Вынимается боеприпас из колчана или другого контейнера частью атаки (для зарядки одноручного оружия вам требуется свободная рука). В конце сражения вы восстанавливаете половину использованных боеприпасов, потратив минуту на поиски на поле боя. Если вы используете оружие со свойством «боеприпас» для совершения рукопашной атаки, вы считаете его импровизированным оружием. Праща при этом должна быть заряжена.\",\n        name: \"&#9876; Боеприпас\" },\n    { key: \"weapon.twohanded\",\n        desc: \"<b>Двуручное.</b> Это оружие нужно держать двумя руками, когда вы атакуете им.\",\n        name: \"&#9876; Двуручное\" },\n    { key: \"weapon.reach\",\n        desc: \"<b>Досягаемость.</b> Это оружие добавляет 5 футов к расстоянию, на котором вы можете совершать этим оружием атаки, а также провоцированные атаки (смотрите главу 9 «Книги игрока»).\",\n        name: \"&#9876; Досягаемость\" },\n    { key: \"weapon.distance\",\n        desc: \"<b>Дистанция. (Дис.)</b> Дальнобойные атаки можно совершать только по целям, находящимся в пределах определённой дистанции. Если у дальнобойной атаки, например, заклинанием, указана только одна дистанция, вы не можете атаковать цели, находящиеся за пределами этой дистанции. <br />У некоторых дальнобойных атак, например, у совершаемых из лука, указаны две дистанции.  У оружия, с помощью которого могут совершаться дальнобойные атаки, диапазон указан в скобках после свойства «боеприпас» или «метательное». Меньшее число — это нормальная дистанция, а большее — максимальная дистанция. Бросок атаки совершается с помехой, если цель за пределами нормальной дистанции, и вы не можете атаковать цель, находящуюся за пределами максимальной дистанции.\",\n        name: \"&#9876; Дистанция\" },\n    { key: \"weapon.special.lance\",\n        desc: \"<b>Особое.</b> Это оружие со свойством «особое» используется по специальным правилам: Вы совершаете с помехой атаки длинным копьём по существам, находящимся в пределах 5 футов от вас. Кроме того, если вы не находитесь верхом, длинное копьё используется двумя руками.\",\n        name: \"&#9876; Копьё\" },\n    { key: \"weapon.light\",\n        desc: \"<b>Лёгкое</b>. Лёгкое оружие маленькое и удобное, и идеально подходит для сражения двумя оружиями. Смотрите правила по сражению двумя оружиями в главе 9 PHB.\",\n        name: \"&#9876; Лёгкое\" },\n    { key: \"weapon.thrown\",\n        desc: \"<b>Метательное.</b> Если у оружия есть свойство «метательное», вы можете совершать им дальнобойные атаки, метая его. Если это рукопашное оружие, вы используете для бросков атаки и урона тот же модификатор характеристики, что и при совершении рукопашной атаки этим оружием. Например, если вы метаете ручной топор, вы используете Силу, а если метаете кинжал, то можете использовать либо Силу, либо Ловкость, так как у кинжала есть свойство «фехтовальное».\",\n        name: \"&#9876; Метательное\" },\n    { key: \"weapon.special\",\n        desc: \"<b>Особое.</b> Оружие со свойством «особое» используется по специальным правилам, указанным в описании этого оружия.\",\n        name: \"&#9876; Особое\" },\n    { key: \"weapon.loading\",\n        desc: \"<b>Перезарядка.</b> Из-за долгой перезарядки этого оружия вы можете выстрелить из него только один боеприпас одним действием, бонусным действием или реакцией, вне зависимости от количества положенных атак.\",\n        name: \"&#9876; Перезарядка\" },\n    { key: \"weapon.special.net\",\n        desc: \"<b>Особое.</b> Это оружие со свойством «особое» используется по специальным правилам: Существа Большого и меньшего размеров, по которым попала атака сетью, становятся опутанными, пока не высвободятся. Сеть не оказывает эффекта на бесформенных существ и тех, чей размер Огромный или ещё больше. Существо может действием совершить проверку Силы со Сл 10, чтобы высвободиться самому или освободить другое существо, находящееся в пределах его досягаемости. Причинение сети 5 единиц рубящего урона (КД 10) тоже освобождает существо, не причиняя ему вреда, оканчивая эффект и уничтожая сеть.\",\n        name: \"&#9876; Сеть\" },\n    { key: \"weapon.heavy\",\n        desc: \"<b>Тяжёлое.</b> Существа Маленького и Крошечного размера совершают броски атаки тяжёлым оружием с помехой. Из-за размера и веса Маленькие и Крошечные существа не могут использовать такое оружие эффективно.\",\n        name: \"&#9876; Тяжёлое\" },\n    { key: \"weapon.versatile\",\n        desc: \"<b>Универсальное.</b> Это оружие можно использовать как одной, так и двумя руками. Урон, указанный в скобках после этого свойства, означает урон при совершении рукопашной атаки двумя руками.\",\n        name: \"&#9876; Универсальное\" },\n    { key: \"weapon.finesse\",\n        desc: \"<b>Фехтовальное.</b> При совершении атаки фехтовальным оружием вы сами выбираете, какой модификатор использовать при совершении бросков атаки и урона — модификатор Силы или Ловкости. Для обоих бросков должен использоваться один и тот же модификатор.\",\n        name: \"&#9876; Фехтовальное\" },\n\n    { key: \"condition.unconscious\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Существо роняет всё, что держит, и падает ничком.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо автоматически проваливает спасброски Силы и Ловкости. Броски атаки по существу совершаются с преимуществом.</li>\\\n\t\t\t<li>&bull;&nbsp;Любая атака, попавшая по такому существу, считается критическим попаданием, если нападающий находится в пределах 5 футов от него.</li>\\\n\t\t\t<li>&bull;&nbsp;Находящееся без сознания существо не способно перемещаться и говорить, не осознаёт своё окружение и <b>недееспособно</b>:</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо не может совершать действия и реакции.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо автоматически проваливает проверки противодействия <b>захвату</b> и <b>толчку</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо теряет концентрацию на заклинании.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Без сознания\" },\n    { key: \"condition.frightened\",\n        desc: \"<ul><li>&bull;&nbsp;Испуганное существо совершает с помехой проверки характеристик и броски атаки, пока источник его страха находится в пределах его линии обзора.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо не способно добровольно приблизиться к источнику своего страха.</li></ul>\",\n        name: \"&#9877; Испуганное\" },\n    { key: \"condition.exhaustion\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;1 степень: Помеха при проверках характеристик</li>\\\n\t\t\t<li>&bull;&nbsp;2 степень: Скорость уменьшается вдвое</li>\\\n\t\t\t<li>&bull;&nbsp;3 степень: Помеха при бросках атаки и спасбросках</li>\\\n\t\t\t<li>&bull;&nbsp;4 степень: Максимум хитов уменьшается вдвое</li>\\\n\t\t\t<li>&bull;&nbsp;5 степень: Скорость снижается до 0</li>\\\n\t\t\t<li>&bull;&nbsp;6 степень: Смерть</li></ul>\",\n        name: \"&#9877; Истощение\" },\n    { key: \"condition.invisible\",\n        desc: \"<ul><li>&bull;&nbsp;Невидимое существо невозможно увидеть без помощи магии или особого чувства. С точки зрения скрытности существо считается сильно заслонённым. Местонахождение существа можно определить по шуму, который оно издаёт, или по оставленным им следам.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по невидимому существу совершаются с помехой, а его броски атаки — с преимуществом.</li></ul>\",\n        name: \"&#9877; Невидимое\" },\n    { key: \"condition.incapacitated\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо не может совершать действия и реакции.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо автоматически проваливает проверки противодействия <b>захвату</b> и <b>толчку</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо теряет концентрацию на заклинании.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Недееспособное\" },\n    { key: \"condition.deafened\",\n        desc: \"<ul><li>&bull;&nbsp;Оглохшее существо ничего не слышит и автоматически проваливает все проверки характеристик, связанные со слухом.</li></ul>\",\n        name: \"&#9877; Оглохшее\" },\n    { key: \"condition.petrified\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Окаменевшее существо, а также все немагические предметы, которые оно несёт или носит, трансформируется в твёрдое инертное вещество (как правило, в камень). Его вес увеличивается в 10 раз, и оно перестаёт стареть.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по существу совершаются с преимуществом.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо автоматически проваливает спасброски Силы и Ловкости.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо получает сопротивление ко всем видам урона.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо получает иммунитет к ядам и болезням. Если яд или болезнь уже действовали на существо, их действие приостанавливается, но не исчезает.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо не способно двигаться и говорить, не осознаёт своё окружение, а также <b>недееспособно</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо не может совершать действия и реакции.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо автоматически проваливает проверки противодействия <b>захвату</b> и <b>толчку</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо теряет концентрацию на заклинании.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Окаменевшее\" },\n    { key: \"condition.restrained\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Скорость опутанного существа равна 0, и оно не получает выгоды ни от каких бонусов к скорости.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по такому существу совершаются с преимуществом, а его броски атаки — с помехой.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо совершает с помехой спасброски Ловкости.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Опутанное\" },\n    { key: \"condition.blinded\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Ослеплённое существо ничего не видит и автоматически проваливает все проверки характеристик, связанные со зрением.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по такому существу совершаются с преимуществом, а его броски атаки совершаются с помехой.</li></ul>\",\n        name: \"&#9877; Ослеплённое\" },\n    { key: \"condition.poisoned\",\n        desc: \"<ul><li>&bull;&nbsp;Отравленное существо совершает с помехой броски атаки и проверки характеристик.</li></ul>\",\n        name: \"&#9877; Отравленное\" },\n    { key: \"condition.charmed\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Очарованное существо не может атаковать того, кто его очаровал, а также делать его целью умения или магического эффекта, причиняющего вред.</li>\\\n\t\t\t<li>&bull;&nbsp;Искуситель совершает с преимуществом все проверки характеристик при социальном взаимодействии с очарованным существом. </li></ul>\",\n        name: \"&#9877; Очарованное\" },\n    { key: \"condition.stunned\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Существо автоматически проваливает спасброски Силы и Ловкости.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по существу совершаются с преимуществом.</li>\\\n\t\t\t<li>&bull;&nbsp;Ошеломлённое существо не способно перемещаться и говорит, запинаясь, а также <b>недееспособно</b>:</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо не может совершать действия и реакции.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо автоматически проваливает проверки противодействия <b>захвату</b> и <b>толчку</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо теряет концентрацию на заклинании.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Ошеломлённое\" },\n    { key: \"condition.paralyzed\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Существо автоматически проваливает спасброски Силы и Ловкости.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по парализованному существу совершаются с преимуществом.</li>\\\n\t\t\t<li>&bull;&nbsp;Любая атака, попавшая по такому существу, считается критическим попаданием, если нападающий находится в пределах 5 футов от существа.</li>\\\n\t\t\t<li>&bull;&nbsp;Парализованное существо не способно перемещаться и говорить, а также <b>недееспособно</b>:</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо не может совершать действия и реакции.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо автоматически проваливает проверки противодействия <b>захвату</b> и <b>толчку</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Недееспособное существо теряет концентрацию на заклинании.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Парализованное\" },\n    { key: \"condition.prone\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Сбитое с ног существо способно перемещаться только ползком, пока не встанет, прервав тем самым это состояние.</li>\\\n\t\t\t<li>&bull;&nbsp;Существо совершает с помехой броски атаки.</li>\\\n\t\t\t<li>&bull;&nbsp;Броски атаки по существу совершаются с преимуществом, если нападающий находится в пределах 5 футов от него. В противном случае броски атаки совершаются с помехой.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Сбитое с ног\" },\n    { key: \"condition.grappled\",\n        desc: \"<ul>\\\n\t\t\t<li>&bull;&nbsp;Скорость схваченного существа равна 0, и оно не получает выгоды ни от каких бонусов к скорости (в частности, не может использовать действие <b>Уклонение</b>).</li>\\\n\t\t\t<li>&bull;&nbsp;Состояние оканчивается, если схвативший становится <b>недееспособен</b>.</li>\\\n\t\t\t<li>&bull;&nbsp;Это состояние также оканчивается, если какой-либо эффект выводит схваченное существо из зоны досягаемости того, кто его удерживает, или из зоны удерживающего эффекта. Например, когда существо отбрасывается заклинанием волна грома.</li>\\\n\t\t\t</ul>\",\n        name: \"&#9877; Схваченное\" },\n\n    { key: \"item.pack.entertainer\",\n        desc: \"Включает рюкзак, спальник, 2 костюма, 5 свечек, рационы на 5 дней, бурдюк и набор для грима.\",\n        name: \"&#9881; артиста\" },\n    { key: \"item.pack.burglar\",\n        desc: \"Включает рюкзак, сумку с 1 000 металлических шариков, 10 футов лески, колокольчик, 5 свечек, ломик, молоток, 10 шлямбуров, закрытый фонарь, 2 фляги масла, рационы на 5 дней, трутницу и бурдюк. В набор также входит 50-футовая пеньковая верёвка, закреплённая сбоку\",\n        name: \"&#9881; взломщика\" },\n    { key: \"item.pack.diplomat\",\n        desc: \"Включает сундук, 2 контейнера для карт и свитков, комплект отличной одежды, бутылочку чернил, писчее перо, лампу, 2 фляги масла, 5 листов бумаги, флакон духов, воск и мыло.\",\n        name: \"&#9881; дипломата\" },\n    { key: \"item.pack.priest\",\n        desc: \"Включает рюкзак, одеяло, 10 свечек, трутницу, коробку для пожертвований, 2 упаковки благовоний, кадило, облачение, рационы на 2 дня и бурдюк.\",\n        name: \"&#9881; жреца\" },\n    { key: \"item.pack.dungeoneer\",\n        desc: \"Включает рюкзак, ломик, молоток, 10 шлямбуров, 10 факелов, трутницу, рационы на 10 дней и бурдюк. В набор также входит 50-футовая пеньковая верёвка, закреплённая сбоку.\",\n        name: \"&#9881; подземелий\" },\n    { key: \"item.pack.explorer\",\n        desc: \"Включает рюкзак, спальник, столовый набор, трутницу, 10 факелов, рационы на 10 дней и бурдюк. В набор также входит 50-футовая пеньковая верёвка, закреплённая сбоку.\",\n        name: \"&#9881; путешественника\" },\n    { key: \"item.pack.scholar\",\n        desc: \"Включает рюкзак, научную книгу, бутылочку чернил, писчее перо, 10 листов пергамента, небольшую сумочку с песком и небольшой нож.\",\n        name: \"&#9881; учёного\" },\n\n    { key: \"obscured.lightly\",\n        desc: \"В <b>слабо заслонённой</b> области, например, в области тусклого света, в тумане, листве, существа совершают с помехой проверки Мудрости (Восприятие), полагающиеся на зрение.\",\n        name: \"&#9887; Слабый заслон\" },\n    { key: \"obscured.heavily\",\n        desc: \"<b>Сильно заслонённая</b> местность — такая, как тьма, густой туман или густая листва — полностью блокирует зрение. Существа фактически считаются <b>ослеплёнными</b>, когда пытаются рассмотреть что-то, находящееся в такой местности.\",\n        name: \"&#9887; Сильный заслон\" },\n\n    { key: \"light.bright\",\n        desc: \"<b>Яркий свет</b> позволяет большинству существ видеть хорошо. Даже пасмурный день предоставляет яркий свет, равно как факелы, фонари, костры и прочие источники света в определённом радиусе.\",\n        name: \"&#9887; Яркий свет\" },\n    { key: \"light.dim\",\n        desc: \"<b>Тусклый свет</b>, также называемый тенью, создаёт <b>слабо заслонённую</b> местность. Область тусклого света обычно находится между источником яркого света, таким как факел, и окружающей темнотой. На рассвете и закате свет тоже тусклый. Яркая луна в полнолуние освещает землю тусклым светом.<br>\\\n\t В <b>слабо заслонённой</b> области, например, в области тусклого света, в тумане, листве, существа совершают с помехой проверки Мудрости (Восприятие), полагающиеся на зрение.\",\n        name: \"&#9887; Тусклый свет\" },\n    { key: \"light.darkness\",\n        desc: \"<b>Темнота</b> создаёт <b>сильно заслонённую</b> местность. Персонажи оказываются в темноте по ночам (когда не светит луна), в коридорах подземелий и в областях магической тьмы.<br>\\\n\t <b>Сильно заслонённая</b> местность — такая, как тьма, густой туман или густая листва — полностью блокирует зрение. Существа фактически считаются <b>ослеплёнными</b>, когда пытаются рассмотреть что-то, находящееся в такой местности.\",\n        name: \"&#9887; Темнота\" },\n\n    { key: \"vision.blindsight\",\n        desc: \"Существо со <b>слепым зрением</b> может воспринимать своё окружение в определённом радиусе, не полагаясь на зрение. Этим чувством обладают существа без глаз, такие как слизи, и существа с эхолокацией или обострёнными чувствами, такие как летучие мыши и драконы.\",\n        name: \"&#9887; Слепое зрение\" },\n    { key: \"vision.darkvision\",\n        desc: \"Многие существа в мирах D&D, особенно те, что обитают под землёй, обладают <b>тёмным зрением</b>. Такие существа могут видеть в темноте, как если бы она была тусклым светом, так что для них эта область считается <b>слабо заслонённой</b>. Однако такие существа не могут в темноте различать цвета, для них это разные оттенки серого.\",\n        name: \"&#9887; Темное зрение\" },\n    { key: \"vision.truevision\",\n        desc: \"Существа с <b>истинным зрением</b> могут в определённом радиусе видеть в обычной и магической <b>темноте</b>, видеть невидимые существа и предметы, автоматически обнаруживать зрительные иллюзии и преуспевать в спасбросках от них, и видеть истинный облик перевёртышей и существ, превращённых магией. Кроме того, зрение таких существ простирается на Эфирный План.\",\n        name: \"&#9887; Истинное зрение\" },\n    { key: \"vision.tremorsense\",\n        desc: \"Чудовища с чувством вибрации могут обнаруживать и определять источник колебаний в пределах определённого радиуса при условии, что чудовище и источник колебаний находятся в контакте с одной и той же поверхностью или веществом. Чувство вибрации не может быть использовано для обнаружения летающих или бесплотных существ. Многие роющие существа, такие как анхеги или бурые увальни, обладают этим чувством.\",\n        name: \"&#9887; Чувство вибрации\" },\n\n    { key: \"cover.full\",\n        desc: \"На цель с <b>полным укрытием</b> нельзя непосредственно нацеливать атаки и заклинания, хотя некоторые заклинания могут захватить цель областью воздействия. Цель обладает полным укрытием если полностью скрыта за препятствием.\",\n        name: \"&#9887; Полное укрытие\" },\n    { key: \"cover.half\",\n        desc: \"Цель с <b>укрытием на половину</b> получает бонус +2 к КД и спасброскам Ловкости. Цель получает укрытие на половину если препятствие закрывает как минимум половину её тела. Это может быть низкая стена, большая мебель, узкий ствол дерева или существо, как враждебное, так и дружественное.\",\n        name: \"&#9887; Полуукрытие\" },\n    { key: \"cover.3quarters\",\n        desc: \"Цель с <b>укрытием на три четверти</b> получает бонус +5 к КД и спасброскам Ловкости. Цель получает укрытие на три четверти если препятствие закрывает как минимум три четверти её тела. Это может быть опускная решётка, бойница в стене или широкий ствол дерева.\",\n        name: \"&#9887; Укрытие 3&#9833;\" },\n\n    { key: \"action.hide\",\n        desc: \"Если вы совершаете действие <b>Засада</b>, вы совершаете проверку Ловкости (Скрытность), пытаясь спрятаться, используя правила из главы 7 КИ. В случае успеха вы получаете определённые преимущества, описанные в разделе «Невидимые атакующие и цели» КИ.\",\n        name: \"&#9850; Засада\" },\n    { key: \"action.grapple\",\n        desc: \"<ul><li>Если вы хотите схватить существо или побороться с ним, вы можете использовать действие Атака для совершения особой рукопашной атаки: <b>захвата</b>. Если вы можете совершать многочисленные атаки действием Атака, эта атака заменяет одну из них. Цель вашего захвата должна быть не более чем на одну категорию больше вас, и она должна находиться в пределах вашей досягаемости.</li><li>Используя как минимум одну свободную руку, вы пытаетесь схватить цель, совершая проверку захвата: проверку Силы (Атлетика), противопоставленную проверке Силы (Атлетика) или Ловкости (Акробатика) цели (по выбору цели; <b>недееспособная</b> цель автоматически проваливает проверку). Если вы преуспеете, цель становится <b>схваченной</b>. В описании состояния сказано, что его оканчивает, и вы в любой момент можете отпустить цель (действие не требуется)</li><li>Захваченное существо может пытаться высвободиться. Для этого оно действием совершает проверку Силы (Атлетика) или Ловкость (Акробатика), противопоставленную вашей проверке Силы (Атлетика)</li><li>Если вы перемещаетесь, вы можете тащить или нести захваченное существо вместе с собой, но ваша скорость уменьшается вдвое, если только существо не меньше вас как минимум на две категории</li></ul>\",\n        name: \"&#9850; Захват\" },\n    { key: \"action.disengage\",\n        desc: \"Если вы совершаете действие <b>Отход</b>, то до конца текущего хода ваше перемещение не провоцирует атаки.\",\n        name: \"&#9850; Отход\" },\n    { key: \"action.search\",\n        desc: \"Совершив действие Поиск, вы уделяете внимание поиску чего-то. В зависимости от характера ваших поисков Мастер может призвать к проверке Мудрости (Восприятие) или Интеллекта (Расследование).\",\n        name: \"&#9850; Поиск\" },\n    { key: \"action.help\",\n        desc: \"Вы можете оказать помощь другому существу.<br />Если вы совершаете действие Помощь, существо, которому вы помогаете, совершит свою следующую проверку характеристики для выполнения задачи с преимуществом, если она будет совершена до начала вашего следующего хода. <br />В качестве альтернативы, вы можете помочь дружественному существу атаковать другое существо, находящееся в пределах 5 футов от вас. Вы совершаете финт, отвлекаете цель или каким-то другим образом делаете атаку союзника более эффективной. Если ваш союзник атакует цель до начала вашего следующего хода, первый бросок атаки совершается с преимуществом.\",\n        name: \"&#9850; Помощь\" },\n    { key: \"action.stabilize\",\n        desc: \"Самый надёжный способ помочь существу с 0 хитов - это его лечение. Если лечение недоступно, существо можно хотя бы <b>стабилизировать</b>, чтобы оно не умерло от проваленного спасброска от смерти. Вы можете действием оказать первую помощь находящемуся без сознания существу и попытаться стабилизировать его, для чего требуется совершить проверку Мудрости (Медицина) со Сл 10.<br>Стабилизированное существо не совершает спасброски от смерти, несмотря на то, что хиты равны 0, но и в сознание не приходит. Получив урон, существо перестаёт быть стабилизированным и снова начинает совершать спасброски от смерти. Стабилизированное существо, не получившее лечения, восстанавливает 1 хит после 1к4 часов.\",\n        name: \"&#9850; Стабилизация\" },\n    { key: \"action.dash\",\n        desc: \"Если вы совершаете действие <b>Рывок</b>, вы получаете дополнительное перемещение в текущем ходу, равное вашей скорости после применения всех модификаторов. Например, если у вас скорость 30 футов, то совершив рывок, вы можете переместиться на 60 футов. Все увеличения и уменьшения скорости изменяют точно так же и дополнительное перемещение. Например, если ваша скорость 30 футов уменьшена до 15 футов, то совершив рывок, вы можете переместиться на 30 футов.\",\n        name: \"&#9850; Рывок\" },\n    { key: \"action.shove\",\n        desc: \"Вы можете при помощи действия Атака совершить особую рукопашную атаку, чтобы или <b>сбить цель с ног</b>, или <b>оттолкнуть</b> от себя. Если вы можете совершать многочисленные атаки действием Атака, эта атака заменяет одну из них. Цель вашего толкания должна быть не более чем на одну категорию больше вас, и она должна находиться в пределах вашей досягаемости. Вы совершаете проверку Силы (Атлетика), противопоставленную проверке Силы (Атлетика) или Ловкости (Акробатика) цели (по выбору цели; <b>недееспособная</b> цель автоматически проваливает проверку). Если вы преуспеете, вы либо сбиваете цель с ног, либо толкаете её на 5 футов от себя.\",\n        name: \"&#9850; Толчок\" },\n    { key: \"action.dodge\",\n        desc: \"Если вы совершаете действие <b>Уклонение</b>, вы сосредотачиваетесь на уклонении от атак. До начала вашего следующего хода все броски атаки по вам совершаются с помехой, и спасброски Ловкости вы совершаете с преимуществом, если вы видите атакующего. Вы теряете это преимущество, если становитесь <b>недееспособным</b> или если ваша скорость падает до 0.\",\n        name: \"&#9850; Уклонение\" },\n    { key: \"action.useItem\",\n        desc: \"Обычно вы взаимодействуете с предметами во время других действий, например, вынимаете меч частью атаки, но если предмет требует действия для его использования, вы совершаете действие <b>Использование предмета</b>. Это действие также пригодится, если вы хотите в течение хода взаимодействовать сразу с несколькими предметами.<br>Если активация магического предмета требует совершения действия, то это действие не равносильно действию Использование предмета, так что умение плута Быстрые руки или дополнительное действие от заклинания Ускорение не могут быть использовано для активации предмета.\",\n        name: \"&#9850; Юз предмета\" },\n\n    { key: \"tools.alchemist\",\n        desc: \"<b>Инструменты алхимика</b> позволяют персонажу создавать полезные варева, такие как кислота или алхимический огонь. Инструменты алхимика включают в себя две стеклянные мензурки, металлический каркас, удерживающий мензурку над открытым пламенем, стеклянную палочку для размешивания, небольшие ступку и пестик, мешочек обычных алхимических ингредиентов, включающих в себя соль, измельчённое железо и дистиллированную воду.\",\n        name: \"&#9773; алхимик\" },\n    { key: \"tools.thief\",\n        desc: \"Возможно, чаще всего используемые искателями приключений, <b>воровские инструменты</b> разработаны для взлома замков и обезвреживания ловушек. Владение этими инструментами также даёт вам общие знания о принципах действия ловушек и замков. Воровские инструменты включают в себя надфиль, набор отмычек, небольшое зеркальце с металлической рукояткой, набор ножниц с узкими лезвиями и пару щипцов.\",\n        name: \"&#9773; воровской\" },\n    { key: \"tools.potter\",\n        desc: \"<b>Инструменты гончара</b> используются для создания различных керамических предметов, наиболее распространённые из них – это горшки и подобные сосуды. Инструменты гончара включают в себя гончарные иглы, цикли, скребки, нож и кронциркуль.\",\n        name: \"&#9773; гончар\" },\n    { key: \"tools.disguise\",\n        desc: \"Отличный выбор для любого, кто хочет заниматься обманом, <b>набор для грима</b> позволяет своему владельцу принимать фальшивую личину. Набор для грима включает в себя различную косметику, краску для волос, немного реквизита и несколько нарядов.\",\n        name: \"&#9773; грим\" },\n    { key: \"tools.gaming\",\n        desc: \"Владение <b>игровым набором</b> применяется к одному виду игры, например, к ставке трёх драконов или к азартным играм, использующим кости. Игровой набор включает в себя всё необходимое для конкретной игры или группы игр, как, например, полная колода карт или доска и фигуры.\",\n        name: \"&#9773; игровой\" },\n    { key: \"tools.calligraph\",\n        desc: \"Каллиграфия трактует письмо как прекрасное утончённое искусство. Каллиграфы создают текст, который радует глаз, используя стиль, который сложно подделать. Их инструменты также дают им возможность исследовать рукописный текст и определить его подлинность, поскольку обучение каллиграфа включало в себя множество часов обучения письму и попыток повторить его стиль и оформление. <b>Инструменты каллиграфа</b> включают в себя чернила, множество пергаментных листов и три писчих пера.\",\n        name: \"&#9773; каллиграф\" },\n    { key: \"tools.mason\",\n        desc: \"<b>Инструменты каменщика</b> позволяют вам возводить каменные строения, включая стены и здания из кирпича. Инструменты каменщика включают в себя мастерок, молоток, долото, щётки и угольник.\",\n        name: \"&#9773; каменщик\" },\n    { key: \"tools.cartograph\",\n        desc: \"Используя <b>инструменты картографа</b>, вы можете составить достоверную карту, чтобы сделать путешествие проще для вас и для тех, кто пойдёт здесь после вас. Это может быть, как крупномасштабная карта, описывающая горные хребты и перевалы, так и схема, показывающая планировку уровня подземелья. Инструменты картографа включают в себя писчее перо, чернила, пергамент, циркуль, кронциркуль и линейку.\",\n        name: \"&#9773; картограф\" },\n    { key: \"tools.leatherwork\",\n        desc: \"Познания в кожевенном деле распространяются на знания о шкурах животных и их свойствах. Они также включают в себя знания о кожаных доспехах и аналогичных вещах. <b>Инструменты кожевника</b> включают кожевенный резак (нож), небольшую киянку, канавкорез, пробойник, нить и куски кожи.\",\n        name: \"&#9773; кожевник\" },\n    { key: \"tools.blacksmith\",\n        desc: \"<b>Инструменты кузнеца</b> позволяют вам работать с металлом, нагревая его для изменения формы, восстанавливая повреждения или создавая из слитков полезные предметы. Инструменты кузнеца включают в себя молоты, клещи, уголь, ветошь и точильный камень.\",\n        name: \"&#9773; кузнец\" },\n    { key: \"tools.music\",\n        desc: \"Владение <b>музыкальным инструментом</b> означает, что вы знакомы с приёмами игры на нём и можете добавлять бонус мастерства к проверкам характеристик, совершённым во время игры на нём. Вы также знаете несколько песен, как правило, исполняющихся на этом инструменте. Бард может использовать музыкальный инструмент в качестве фокусировки для заклинаний (см. главу 10 КИ). Для каждого музыкального инструмента нужно отдельное владение. Самые популярные музыкальные инструменты: виола, волынка, барабан, лира, лютня, рожок, свирель, флейта, цимбалы, шалмей.\",\n        name: \"&#9773; музыкант\" },\n    { key: \"tools.navigator\",\n        desc: \"Владение <b>инструментами навигатора</b> помогает вам определить истинный курс, основываясь на наблюдении за звёздами. Они также позволяют вам разбираться в чтении схем и карт, благодаря выработанному у вас чувство направления. Инструменты навигатора включают в себя секстант, компас, кронциркуль, линейку, пергамент, чернила и писчее перо.\",\n        name: \"&#9773; навигатор\" },\n    { key: \"tools.poisoner\",\n        desc: \"<b>Инструменты отравителя</b> — это излюбленное средство воров, убийц и прочих сомнительных личностей. Они позволяют вам использовать яды и создавать их из различных веществ. Ваши познания в ядах также помогают вам излечивать от них. Инструменты отравителя включают в себя стеклянные склянки, ступку и пестик, химические реагенты и стеклянную палочку для размешивания.\",\n        name: \"&#9773; отравитель\" },\n    { key: \"tools.brewer\",\n        desc: \"Пивоварение – это искусство производства пива. Но этот процесс может использоваться не только для создания алкогольных напитков, но и для очищения воды. Для создания пива требуются недели на ферментацию, но всего несколько часов непосредственно на работу. <b>Инструменты пивовара</b> включают в себя большую стеклянную бутыль, некоторое количество хмеля, сифон, змеевик и несколько футов трубок.\",\n        name: \"&#9773; пивовар\" },\n    { key: \"tools.carpenter\",\n        desc: \"Навыки плотничества позволяют персонажу строить деревянные сооружения. Плотник может построить дом, хижину, деревянный шкаф или подобный предмет. <b>Инструменты плотника</b> включают в себя пилу, молоток, гвозди, топор, угольник, линейку, кородёр, рубанок и стамеску.\",\n        name: \"&#9773; плотник\" },\n    { key: \"tools.cook\",\n        desc: \"Жизнь искателя приключений тяжела. При наличии в компании повара ваша пища будет намного вкуснее, чем привычные галеты и сухофрукты. <b>Инструменты повара</b> включают в себя металлический котёл, ножи, вилки, ложку для размешивания и половник.\",\n        name: \"&#9773; повар\" },\n    { key: \"tools.woodcarver\",\n        desc: \"<b>Инструменты резчика по дереву</b> позволяют вам создавать сложные предметы из дерева, такие как деревянные фигурки или стрелы. Инструменты резчика по дереву включают в себя нож, стамеску и маленькую пилу.\",\n        name: \"&#9773; резчик\" },\n    { key: \"tools.tinker\",\n        desc: \"Набор <b>инструментов ремонтника</b> предназначен для того, чтобы чинить множество обычных предметов. И хотя вы не можете создать большинство из них инструментами ремонтника, вы можете починить порвавшуюся одежду, наточить затупившийся меч и подлатать истрепавшуюся кольчугу. Инструменты ремонтника включают в себя различные ручные инструменты, нитки, иголки, точильный камень, куски ткани и кожи, небольшую банку клея (синюю изоленту пока, увы, не придумали).\",\n        name: \"&#9773; ремонтник\" },\n    { key: \"tools.cobbler\",\n        desc: \"Несмотря на то, что профессия сапожника может показаться искателю приключений слишком простой, пара хороших сапог будет сопровождать персонажа и в труднопроходимой глуши, и в смертельных подземельях. <b>Инструменты сапожника</b> включают в себя молоток, шило, нож, обувную колодку, ножницы, запас кожи и ниток.\",\n        name: \"&#9773; сапожник\" },\n    { key: \"tools.glassblower\",\n        desc: \"Владеющий <b>инструментами стеклодува</b> не только умеет выдувать стекло, но также знает особые методики изготовления стеклянных предметов. Инструменты стеклодува включают в себя трубку для выдувания, маленькую стеклодувную обкатку, катальник, развёртки и щипцы. Вам нужен источник тепла для работы со стеклом.\",\n        name: \"&#9773; стеклодув\" },\n    { key: \"tools.weaver\",\n        desc: \"<b>Инструменты ткача</b> позволяют вам шить одежду и подгонять её по фигуре. Инструменты ткача включают в себя нитки, иголки и куски ткани. Вы умеете пользоваться ткацким станком, но подобное оборудование слишком громоздкое для транспортировки.\",\n        name: \"&#9773; ткач\" },\n    { key: \"tools.herbalist\",\n        desc: \"Владение <b>набором травника</b> позволяет вам распознавать растения и надёжно сохранять их полезные части. Набор травника включает в себя мешочки для хранения трав, секатор и кожаные перчатки для сбора растений, несколько стеклянных банок, ступку и пестик.\",\n        name: \"&#9773; травник\" },\n    { key: \"tools.vehicles\",\n        desc: \"Владение <b>наземным транспортом</b> покрывает широкий спектр вариантов, от колесниц и хаудахов до повозок и телег. Владение <b>водным транспортом</b> охватывает всё, что перемещается по водным путям. Владение транспортом предоставляет знания, необходимые для управления транспортом данного типа, вместе со знаниями о том, как его чинить и обслуживать. Кроме того, персонаж, владеющий водным транспортом, осведомлён обо всём, что должен знать профессиональный моряк, как то знание информации о море и островах, умение завязывать узлы и оценивать погоду и волнение моря.\",\n        name: \"&#9773; транспорт\" },\n    { key: \"tools.forgery\",\n        desc: \"<b>Набор для фальсификации</b> предназначен для копирования документов и упрощения копирования личной печати или подписи. Набор для фальсификации включает в себя чернила различных видов, пергамент и бумагу различных видов, несколько писчих перьев, печати и сургуч, золотой и серебряный листы и небольшие инструменты для лепки из расплавленного воска имитации печати.\",\n        name: \"&#9773; фальсификат\" },\n    { key: \"tools.painter\",\n        desc: \"Владение <b>инструментами художника</b> позволяет вам писать красками и рисовать карандашом. Вы также разбираетесь в истории искусств, что может помочь вам при осмотре произведений искусства. Инструменты художника включают в себя мольберт, холст, краски, кисти, угольные карандаши и палитру.\",\n        name: \"&#9773; художник\" },\n    { key: \"tools.jeweler\",\n        desc: \"Владение <b>инструментами ювелира</b> включает в себя знание основных способов работы с драгоценностями. Также оно позволяет опознавать драгоценные камни. Инструменты ювелира включают в себя небольшие пилу и молоточек, напильники, щипцы и пинцет.\",\n        name: \"&#9773; ювелир\" },\n\n    { key: \"death.instant\",\n        desc: \"Большой урон может убить вас мгновенно. Если урон опускает ваши хиты до 0, и ещё остаются излишки, вы умираете, если излишки равны максимуму ваших хитов или превышают его.<br/>Например, у жрицы с максимумом хитов 12 сейчас 6 хитов. Если она получает от атаки урон 18, хиты опускаются до 0, но остаётся ещё 12 урона. Так как этот урон равен максимуму хитов, жрица умирает.\",\n        name: \"Мгновенная &#9760;\" },\n\n    { key: \"terrain.difficult\",\n        desc: \"Сражения редко происходят в пустых комнатах и ровных полях. Окружение — щебень, кусты и крутые лестницы — может создавать <b>труднопроходимую местность</b>. Каждый фут перемещения по труднопроходимой местности стоит 1 дополнительный фут. Это правило действует даже если на одно и то же место действуют сразу несколько эффектов, делающих его труднопроходимым, таких как подлесок, крутые ступени, снег или мелкое болото. Пространство другого существа, как враждебного, так и нет, тоже считается труднопроходимой местностью.\",\n        name: \"Труднопроходимое\" },\n\n    { key: \"extreme.heat\",\n        desc: \"При температуре выше 37&#8451; градусов существо, находящееся на жаре без доступа к питьевой воде,должно в конце каждого часа преуспевать в спасброске Телосложения, иначе оно получит одну степень истощения. Сл равна 5 для первого часа, и увеличивается на 1 за каждый дополнительный час. Существа, носящие средние или тяжёлые доспехи, а также те, кто носит плотную одежду, совершают этот спасбросок с помехой. Существа с сопротивлением или иммунитетом к урону огнём автоматически преуспевают в этом спасброске, равно как и существа, адаптировавшиеся к жаркому климату.\",\n        name: \"Экстрем. жара\" },\n    { key: \"extreme.cold\",\n        desc: \"При температуре ниже −17&#8451; градусов существо, находящееся на холоде, должно в конце каждого часа преуспевать в спасброске Телосложения Сл 10, иначе оно получит одну степень истощения. Существа с сопротивлением или иммунитетом к урону холодом автоматически преуспевают в этом спасброске, равно как и тепло одетые существа (толстые куртки, варежки, и так далее) и существа, адаптировавшимся к холодному климату.\",\n        name: \"Экстрем. холод\" },\n    { key: \"extreme.wind\",\n        desc: \"Сильный ветер накладывает помеху к броскам дальнобойных атак оружием и проверкам Мудрости (Восприятие), полагающимся на слух. Сильный ветер также гасит открытое пламя, рассеивает туман и делает полёт без помощи магии практически невозможным. Летающее существо при сильном ветре должно приземляться в конце каждого своего хода, иначе оно падает. Сильный ветер в пустыне может создать песчаную бурю, которая накладывает помеху к проверкам Мудрости (Восприятие), полагающимся на зрение.\",\n        name: \"Экстрем. ветер\" },\n    { key: \"extreme.rain\",\n        desc: \"Всё в области сильного дождя или снегопада считается слабо заслонённым, и существа в этой области совершают с помехой проверки Мудрости (Восприятие), полагающиеся на зрение. Силь-ный дождь также гасит открытое пламя и накладывает помеху на проверки Мудрости (Восприятие), полагающиеся на слух.\",\n        name: \"Экстрем. осадки\" },\n\n    { key: \"skill.acrobatics\",\n        desc: \"Проверки <b>Ловкости (Акробатика)</b> охватывают попытки устоять на ногах в неудобной ситуации, например, когда вы пытаетесь пробежаться по льду, балансируете на натянутом канате или стоите на палубе корабля в шторм. Мастер может также призвать к проверке Ловкости (Акробатика), чтобы увидеть, можете ли вы выполнить акробатический трюк, включая ныряние, кувырки, сальто и перекаты.\",\n        name: \"&#9772; Акробатика\" },\n    { key: \"skill.athletics\",\n        desc: \"<ul><li>Проверки <b>Силы (Атлетика)</b> покрывают разнообразные ситуации, в которых вы лазаете, прыгаете или плаваете. Примеры включают следующие действия:</li><li>&bull;&nbsp;Вы пытаетесь взобраться на крутой утёс, избегая при этом опасностей, или попытки удержаться за что-то, когда вас пытаются стряхнуть.</li><li>&bull;&nbsp;Вы пытаетесь прыгнуть на большое расстояние или совершить трюк в середине прыжка.</li><li>&bull;&nbsp;Вы пытаетесь плыть или оставаться на плаву в бурных водах, во время шторма или среди зарослей водорослей. Другое существо может попытаться толкнуть или затянуть вас под воду, или как-то иным способом помешать вашему плаванию.</li></ul>\",\n        name: \"&#9772; Атлетика\" },\n    { key: \"skill.perception\",\n        desc: \"Проверка <b>Мудрости (Восприятие)</b> позволяет вам увидеть, услышать или как-то иначе заметить присутствие чего-либо. Она измеряет вашу готовность к новым событиям и остроту ваших чувств. Например, вы можете подслушать разговор под дверью, подсмотреть в окно или услышать чудовищ, крадущихся по лесу. Или вы можете попытаться заметить что-то, что скрыто или легко можно пропустить, будь то орки, лежащие в засаде у дороги, головорезы, затаившиеся в тенях аллеи или свет от лампы под закрытой потайной дверью.\",\n        name: \"&#9772; Восприятие\" },\n    { key: \"skill.survival\",\n        desc: \"Мастер может призвать совершить проверку <b>Мудрости (Выживание)</b> для выслеживания врагов, охоты на дичь, нахождения дороги в промёрзшей тундре, замечания признаков того, что рядом живут совомеды, предсказывания погоды и избегания зыбучих песков и прочих природных опасностей.\",\n        name: \"&#9772; Выживание\" },\n    { key: \"skill.intimidation\",\n        desc: \"Когда вы пытаетесь воздействовать на других угрозами, враждебными действиями и физическим насилием, Мастер может попросить вас совершить проверку <b>Харизмы (Запугивание)</b>. Примерами могут послужить добыча информации из пленника, убеждение головорезов отказаться от драки и угроза разбитой бутылкой ехидному визирю, чтобы тот изменил решение.\",\n        name: \"&#9772; Запугивание\" },\n    { key: \"skill.performance\",\n        desc: \"Ваша проверка <b>Харизмы (Выступление)</b> определяет, насколько хорошо вы удовлетворили публику музыкой, танцем, актёрской игрой, рассказом или другим развлечением.\",\n        name: \"&#9772; Выступление\" },\n    { key: \"skill.history\",\n        desc: \"Проверка <b>Интеллекта (История)</b> определяет вашу способность вспомнить знания об исторических событиях, легендарных личностях, древних королевствах, былых спорах, недавних войнах и утерянных цивилизациях.\",\n        name: \"&#9772; История\" },\n    { key: \"skill.sleightOfHand\",\n        desc: \"Если вы пытаетесь жонглировать или сделать ловкий трюк, например, подбросить что-то другому или спрятать что-то на своём теле, совершите проверку <b>Ловкости (Ловкость рук)</b>. Мастер может призвать совершить проверку Ловкости (Ловкость рук) чтобы определить, можете ли вы срезать у ротозея кошелёк или подбросить что-то другому в карман.\",\n        name: \"&#9772; Ловкость рук\" },\n    { key: \"skill.arcana\",\n        desc: \"Проверка <b>Интеллекта (Магия)</b> определяет вашу способность вспомнить знания о заклинаниях, магических предметах, мистических символах, магических традициях, планах существования и обитателях этих планов.\",\n        name: \"&#9772; Магия\" },\n    { key: \"skill.medicine\",\n        desc: \"Проверка <b>Мудрости (Медицина)</b> позволяет стабилизировать умирающего спутника или диагностировать болезнь.\",\n        name: \"&#9772; Медицина\" },\n    { key: \"skill.deception\",\n        desc: \"Ваша проверка <b>Харизмы (Обман)</b> определяет, можете ли вы намеренно утаить правду, хоть речами, хоть действиями. Такой обман охватывает всё, от направления других по неверному следу и двусмысленных речей до рассказывания откровенной лжи. Может применяться при отвлечении стражников, обмане торговцев, зарабатывании денег азартными играми, маскировке под других, отводе чужих подозрений ложными утверждениями и сохранении спокойного лица при рассказывании чудовищной лжи.\",\n        name: \"&#9772; Обман\" },\n    { key: \"skill.nature\",\n        desc: \"Проверка <b>Интеллекта (Природа)</b> определяет вашу способность вспомнить знания о местности, о растениях и животных, о погоде и естественных циклах.\",\n        name: \"&#9772; Природа\" },\n    { key: \"skill.insight\",\n        desc: \"Ваша проверка <b>Мудрости (Проницательность)</b> определяет, можете ли вы определить истинные намерения существа, например, при попытке распознать ложь или предсказать чей-то следующий шаг. При этом вы совершаете догадки по языку тела, особенностям разговора и переменах в поведении.\",\n        name: \"&#9772; Проницатель\" },\n    { key: \"skill.investigation\",\n        desc: \"Если вы ищете подсказки и делаете на их основе выводы, вы совершаете проверку <b>Интеллекта (Расследование)</b>. Вы можете вычислить местоположение спрятанного предмета, понять по виду раны, каким оружием она была нанесена или определить самую слабую точку в туннеле, способную его обрушить. Рассматривание древних свитков в поисках тайного знания тоже может требовать совершения проверки Интеллекта (Расследование).\",\n        name: \"&#9772; Расследование\" },\n    { key: \"skill.religion\",\n        desc: \"Проверка <b>Интеллекта (Религия)</b> определяет вашу способность вспомнить знания о божествах, ритуалах и молитвах, религиозных иерархиях, священных символах и практиках тайных культов.\",\n        name: \"&#9772; Религия\" },\n    { key: \"skill.stealth\",\n        desc: \"Совершите проверку <b>Ловкости (Скрытность)</b>, когда пытаетесь спрятаться от врагов, прокрасться мимо стражи, сбежать незамеченным или незаметно и неслышно подобраться к кому-то.\",\n        name: \"&#9772; Скрытность\" },\n    { key: \"skill.persuasion\",\n        desc: \"Если вы пытаетесь повлиять на существо или целую группу существ тактично, с уважением и добродушием, Мастер может попросить вас совершить проверку <b>Харизмы (Убеждение)</b>. Обычно убеждение используется при добрых намерениях, при попытках подружиться, установить контакт или проявить этикет. Примеры убеждения других включают в себя попытки убедить дворецкого пропустить вас к королю, мирное урегулирование споров двух враждующих племён и воодушевление толпы горожан.\",\n        name: \"&#9772; Убеждение\" },\n    { key: \"skill.animalHandling\",\n        desc: \"Если возникает вопрос, можете ли вы успокоить одомашненное животное, удержать скакуна от того, чтобы он запаниковал, или почувствовать намерения животного, Мастер может призвать совершить проверку <b>Мудрости (Уход за животными)</b>. Вы также совершаете проверку Мудрости (Уход за животными) для контролирования скакуна при совершении опасного манёвра.\",\n        name: \"&#9772; Уход за &#9822;\" },\n\n    { key: \"size.tiny\",\n        desc: \"Крошечное существо занимает пространство в <nobr>2,5 × 2,5 фута</nobr>. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Крошечный\" },\n    { key: \"size.small\",\n        desc: \"Маленькое существо занимает пространство в <nobr>5 × 5 футов</nobr>. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Маленький\" },\n    { key: \"size.medium\",\n        desc: \"Среднее существо занимает пространство в <nobr>5 × 5 футов</nobr>. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Средний\" },\n    { key: \"size.large\",\n        desc: \"Большое существо занимает пространство в <nobr>10 × 10 футов</nobr>. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Большой\" },\n    { key: \"size.huge\",\n        desc: \"Огромное существо занимает пространство в <nobr>15 × 15 футов</nobr>. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Огромный\" },\n    { key: \"size.gargantuan\",\n        desc: \"Громадное существо занимает пространство в <nobr>20 × 20 футов</nobr> или больше. Занимаемое пространство — это площадь, контролируемая существом в бою, а не его габариты.\",\n        name: \"Громадный\" },\n\n\n    { key: \"combat.tempHP\",\n        desc: \"Некоторые заклинания и особые умения дают существам <b>временные хиты</b>. Временные хиты это не настоящие хиты; это заслон от урона, буфер, защищающий от ран.<br>\\\n            Если у вас есть временные хиты и вы получаете урон, временные хиты снимаются первыми, а излишки урона переносятся на обычные хиты. Например, если у вас есть 5 временных хитов и вы получаете урон 7, вы теряете все временные хиты и получаете урон 2.<br>\\\n            Из-за того, что временные хиты это не настоящие хиты, их количество может превышать максимум хитов. Таким образом, персонаж может иметь полные хиты и получать при этом временные хиты.<br>\\\n            Лечение не восстанавливает временные хиты, и они не складываются вместе. Если у вас есть временные хиты, и вы получаете ещё некоторое количество их, вы сами решаете, какие использовать: старые или новые. Например, если заклинание дарует вам 12 временных хитов, когда у вас уже есть 10, у вас может быть или 10 или 12 временных хитов, но не 22.<br>\\\n            Если у вас 0 хитов, получение временных хитов не приводит вас в сознание и не стабилизирует вас. Они всё ещё могут поглощать урон, причиняемый вам, но спасти вас может только настоящее лечение.<br>\\\n            Если умение, даровавшее временные хиты, не указывает их длительность, они существуют, пока не кончатся или пока вы не закончите продолжительный отдых.\",\n        name: \"Временные хиты\" },\n\n    { key: \"option.TCE\",\n        desc: \"Эта опция представлена в книге «<b>Котёл Таши со всякой всячиной</b>». Всё в этой книге <b>опционально</b>: поговорите с Мастером и решите, можно ли вам получить умение или опцию, если вы соответствуете его требованиям. По договорённости с Мастером вы можете использовать некоторые из них, все или ни одну.\",\n        name: \"Опция из TCE\" },\n\n    { key: \"option.rareDice\",\n        desc: \"Некоторые кости не входят в стандартный набор, но изредка всё же используются. Часть таких бросков можно несложно делать, используя стандартные кости, например, так:\\\n\t\t <ul>\\\n\t\t <li><b>к2</b> — бросьте к6; нечётный результат будет означать 1, чётный 2. Или используйте обычную монету.</li>\\\n\t\t <li><b>к3</b> — бросьте к6; результаты 1 и 2 будут означать «1», 3 и 4 — «2», 5 и 6 — «3».</li>\\\n\t\t <li><b>к5</b> — бросьте к20; результаты от 1 до 4 будут означать «1», 5-8 — «2», 9-12 — «3», 13-16 — «4», 17-20 — «5».</li>\\\n\t\t <li><b>к7</b> — бросьте к8; используйте результат броска, если только не выпало «8» — в таком случае перебросьте к8.</li>\\\n\t\t </ul>\",\n        name: \"Редкие кости (д3, д5, д7)\" },\n];\n\nconst items = {\n    weapons: [\n        {\n            title: \"Боевой посох\",\n            damage: \"1к6 дробящий\", props: \"Универсальное&nbsp;(1к8)\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"2 см.\", weight: \"4 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Булава\",\n            damage: \"1к6 дробящий\", props: \"-\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"5 зм.\", weight: \"4 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Дубинка\",\n            damage: \"1к4 дробящий\", props: \"Лёгкое\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"1 см.\", weight: \"2 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Кинжал\",\n            damage: \"1к4 колющий\", props: \"Лёгкое, метательное&nbsp;(20/60), фехтовальное\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"2 зм.\", weight: \"1 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Копьё\",\n            damage: \"1к6 колющий\", props: \"Метательное&nbsp;(20/60), универсальное&nbsp;(1к8)\",\n            tags: [\"простое\", \"рукопашное\", \"копье\"], cost: \"1 зм.\", weight: \"3 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Лёгкий молот\",\n            damage: \"1к4 дробящий\", props: \"Лёгкое, метательное&nbsp;(20/60)\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"2 зм.\", weight: \"2 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Метательное копьё\",\n            damage: \"1к6 колющий\", props: \"Метательное&nbsp;(30/120)\",\n            tags: [\"простое\", \"рукопашное\", \"копье\"], cost: \"5 см.\", weight: \"2 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Палица\",\n            damage: \"1к8 дробящий\", props: \"Двуручное\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"2 см.\", weight: \"10 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Ручной топор\",\n            damage: \"1к6 рубящий\", props: \"Лёгкое, метательное&nbsp;(20/60)\",\n            tags: [\"простое\", \"рукопашное\", \"топор\"], cost: \"5 зм.\", weight: \"2 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Серп\",\n            damage: \"1к4 рубящий\", props: \"Лёгкое\",\n            tags: [\"простое\", \"рукопашное\"], cost: \"1 зм.\", weight: \"2 фнт.\", kind: \"простое рукопашное\",\n        },\n        {\n            title: \"Арбалет, лёгкий\",\n            damage: \"1к8 колющий\", props: \"Боеприпас&nbsp;(80/320), двуручное, перезарядка\",\n            tags: [\"простое\", \"дальнобойное\"], cost: \"25 зм.\", weight: \"5 фнт.\", kind: \"простое дальнобойное\",\n        },\n        {\n            title: \"Дротик\",\n            damage: \"1к4 колющий\", props: \"Метательное&nbsp;(20/60), фехтовальное\",\n            tags: [\"простое\", \"дальнобойное\"], cost: \"5 мм.\", weight: \"1/4 фнт.\", kind: \"простое дальнобойное\",\n        },\n        {\n            title: \"Короткий лук\",\n            damage: \"1к6 колющий\", props: \"Боеприпас&nbsp;(80/320), двуручное\",\n            tags: [\"простое\", \"дальнобойное\", \"лук\"], cost: \"25 зм.\", weight: \"2 фнт.\", kind: \"простое дальнобойное\",\n        },\n        {\n            title: \"Праща\",\n            damage: \"1к4 дробящий\", props: \"Боеприпас&nbsp;(30/120)\",\n            tags: [\"простое\", \"дальнобойное\"], cost: \"1 см.\", weight: \"-\", kind: \"простое дальнобойное\",\n        },\n        {\n            title: \"Алебарда\",\n            damage: \"1к10 рубящий\", props: \"Двуручное, досягаемость, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"20 зм.\", weight: \"6 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Боевая кирка\",\n            damage: \"1к8 колющий\", props: \"-\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"5 зм.\", weight: \"2 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Боевой молот\",\n            damage: \"1к8 дробящий\", props: \"Универсальное&nbsp;(1к10)\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"15 зм.\", weight: \"2 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Боевой топор\",\n            damage: \"1к8 рубящий\", props: \"Универсальное&nbsp;(1к10)\",\n            tags: [\"воинское\", \"рукопашное\", \"топор\"], cost: \"10 зм.\", weight: \"4 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Глефа\",\n            damage: \"1к10 рубящий\", props: \"Двуручное, досягаемость, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"20 зм.\", weight: \"6 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Двуручный меч\",\n            damage: \"2к6 рубящий\",\n            props: \"Двуручное, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\", \"меч\", \"рубящий меч\"],\n            cost: \"50 зм.\",\n            weight: \"6 фнт.\",\n            kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Длинное копьё\",\n            damage: \"1к12 колющий\", props: \"Досягаемость, особое\",\n            tags: [\"воинское\", \"рукопашное\", \"копье\"], cost: \"10 зм.\", weight: \"6 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Длинный меч\",\n            damage: \"1к8 рубящий\",\n            props: \"Универсальное&nbsp;(1к10)\",\n            tags: [\"воинское\", \"рукопашное\", \"меч\", \"рубящий меч\"],\n            cost: \"15 зм.\",\n            weight: \"3 фнт.\",\n            kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Кнут\",\n            damage: \"1к4 рубящий\", props: \"Досягаемость, фехтовальное\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"2 зм.\", weight: \"3 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Короткий меч\",\n            damage: \"1к6 колющий\", props: \"Лёгкое, фехтовальное\",\n            tags: [\"воинское\", \"рукопашное\", \"меч\"], cost: \"10 зм.\", weight: \"2 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Молот\",\n            damage: \"2к6 дробящий\", props: \"Двуручное, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"10 зм.\", weight: \"10 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Моргенштерн\",\n            damage: \"1к8 колющий\", props: \"-\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"15 зм.\", weight: \"4 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Пика\",\n            damage: \"1к10 колющий\", props: \"Двуручное, досягаемость, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"5 зм.\", weight: \"18 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Рапира\",\n            damage: \"1к8 колющий\", props: \"Фехтовальное\",\n            tags: [\"воинское\", \"рукопашное\", \"меч\"], cost: \"25 зм.\", weight: \"2 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Секира\",\n            damage: \"1к12 рубящий\", props: \"Двуручное, тяжёлое\",\n            tags: [\"воинское\", \"рукопашное\", \"топор\"], cost: \"30 зм.\", weight: \"7 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Скимитар\",\n            damage: \"1к6 рубящий\",\n            props: \"Лёгкое, фехтовальное\",\n            tags: [\"воинское\", \"рукопашное\", \"меч\", \"рубящий меч\"],\n            cost: \"25 зм.\",\n            weight: \"3 фнт.\",\n            kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Трезубец\",\n            damage: \"1к6 колющий\", props: \"Метательное&nbsp;(20/60), Универсальное&nbsp;(1к8)\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"5 зм.\", weight: \"4 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Цеп\",\n            damage: \"1к8 дробящий\", props: \"-\",\n            tags: [\"воинское\", \"рукопашное\"], cost: \"10 зм.\", weight: \"2 фнт.\", kind: \"воинское рукопашное\",\n        },\n        {\n            title: \"Ручной арбалет\",\n            damage: \"1к6 колющий\", props: \"Боеприпас&nbsp;(30/120), лёгкое, перезарядка\",\n            tags: [\"воинское\", \"дальнобойное\"], cost: \"75 зм.\", weight: \"3 фнт.\", kind: \"воинское дальнобойное\",\n        },\n        {\n            title: \"Тяжёлый арбалет\",\n            damage: \"1к10 колющий\", props: \"Боеприпас&nbsp;(100/400), двуручное, перезарядка, тяжёлое\",\n            tags: [\"воинское\", \"дальнобойное\"], cost: \"50 зм.\", weight: \"18 фнт.\", kind: \"воинское дальнобойное\",\n        },\n        {\n            title: \"Длинный лук\",\n            damage: \"1к8 колющий\", props: \"Боеприпас&nbsp;(150/600), двуручное, тяжёлое\",\n            tags: [\"воинское\", \"дальнобойное\", \"лук\"], cost: \"50 зм.\", weight: \"2 фнт.\", kind: \"воинское дальнобойное\",\n        },\n        {\n            title: \"Духовая трубка\",\n            damage: \"1 колющий\", props: \"Боеприпас&nbsp;(25/100), перезарядка\",\n            tags: [\"воинское\", \"дальнобойное\"], cost: \"10 зм.\", weight: \"1 фнт.\", kind: \"воинское дальнобойное\",\n        },\n        {\n            title: \"Сеть\",\n            damage: \"-\", props: \"Метательное&nbsp;(5/15), особое\",\n            tags: [\"воинское\", \"дальнобойное\"], cost: \"1 зм.\", weight: \"3 фнт.\", kind: \"воинское дальнобойное\",\n        },\n        {\n            title: \"Пистоль\",\n            damage: \"1к10 колющий\",\n            props: \"Боеприпас&nbsp;(30/90), перезарядка\",\n            tags: [\"воинское\", \"дальнобойное\", \"огнестрельное\"],\n            cost: \"250 зм.\",\n            weight: \"3 фнт.\",\n            kind: \"огнестрельное\",\n        },\n        {\n            title: \"Мушкет\",\n            damage: \"1к12 колющий\",\n            props: \"Боеприпас&nbsp;(40/120), двуручное, перезарядка\",\n            tags: [\"воинское\", \"дальнобойное\", \"огнестрельное\"],\n            cost: \"500 зм.\",\n            weight: \"10 фнт.\",\n            kind: \"огнестрельное\",\n        },\n    ],\n    armor: [\n        {\n            title: \"Стеганый\", props: \"11 + ЛОВ\", stealth: \"Помеха\",\n            tags: [\"легкий\"], cost: \"5 зм.\", weight: \"8 фнт.\", kind: \"Лёгкий доспех\", strength: \"\",\n        },\n        {\n            title: \"Кожаный\", props: \"11 + ЛОВ\", stealth: \"\",\n            tags: [\"легкий\"], cost: \"10 зм.\", weight: \"10 фнт.\", kind: \"Лёгкий доспех\", strength: \"\",\n        },\n        {\n            title: \"Проклёпанный кожаный\", props: \"12 + ЛОВ\", stealth: \"\",\n            tags: [\"легкий\"], cost: \"45 зм.\", weight: \"13 фнт.\", kind: \"Лёгкий доспех\", strength: \"\",\n        },\n        {\n            title: \"Шкурный\", props: \"12 + ЛОВ (макс. 2)\", stealth: \"\",\n            tags: [\"средний\"], cost: \"10 зм.\", weight: \"12 фнт.\", kind: \"Средний доспех\", strength: \"\",\n        },\n        {\n            title: \"Кольчужная рубаха\", props: \"13 + ЛОВ (макс. 2)\", stealth: \"\",\n            tags: [\"средний\", \"металлик\"], cost: \"50 зм.\", weight: \"20 фнт.\", kind: \"Средний доспех\", strength: \"\",\n        },\n        {\n            title: \"Чешуйчатый\", props: \"14 + ЛОВ (макс. 2)\", stealth: \"Помеха\",\n            tags: [\"средний\", \"металлик\"], cost: \"50 зм.\", weight: \"45 фнт.\", kind: \"Средний доспех\", strength: \"\",\n        },\n        {\n            title: \"Кираса\", props: \"14 + ЛОВ (макс. 2)\", stealth: \"\",\n            tags: [\"средний\", \"металлик\"], cost: \"400 зм.\", weight: \"20 фнт.\", kind: \"Средний доспех\", strength: \"\",\n        },\n        {\n            title: \"Полулаты\", props: \"15 + ЛОВ (макс. 2)\", stealth: \"Помеха\",\n            tags: [\"средний\", \"металлик\"], cost: \"750 зм.\", weight: \"40 фнт.\", kind: \"Средний доспех\", strength: \"\",\n        },\n        {\n            title: \"Колечный\", props: \"14\", stealth: \"Помеха\",\n            tags: [\"тяжелый\", \"металлик\"], cost: \"30 зм.\", weight: \"40 фнт.\", kind: \"Тяжёлый доспех\", strength: \"\",\n        },\n        {\n            title: \"Кольчуга\", props: \"16\", stealth: \"Помеха\",\n            tags: [\"тяжелый\", \"металлик\"], cost: \"75 зм.\", weight: \"55 фнт.\", kind: \"Тяжёлый доспех\", strength: \"13\",\n        },\n        {\n            title: \"Наборный\", props: \"17\", stealth: \"Помеха\",\n            tags: [\"тяжелый\", \"металлик\"], cost: \"200 зм.\", weight: \"60 фнт.\", kind: \"Тяжёлый доспех\", strength: \"15\",\n        },\n        {\n            title: \"Латы\", props: \"18\", stealth: \"Помеха\",\n            tags: [\"тяжелый\", \"металлик\"], cost: \"1 500 зм.\", weight: \"65 фнт.\", kind: \"Тяжёлый доспех\", strength: \"15\",\n        },\n        {\n            title: \"Щит\", props: \"+2\", stealth: \"\",\n            tags: [\"Щиты\"], cost: \"10 зм.\", weight: \"6 фнт.\", kind: \"Щит\", strength: \"\",\n        },\n    ],\n};\n\n//# sourceURL=webpack://DnD.su/./source/scripts/modules/Tooltip/TooltipData.js?");

